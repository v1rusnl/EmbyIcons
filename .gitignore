## ---- Benutzerdefiniert für EmbyIcons ----
# Diese Ordner sollen NICHT zu GitHub
obj/
.vs/

## ---- Standard Visual Studio .gitignore ----

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
[Bb]uild[Ll]og.*


# Visual Studio files
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Cache / temp files
*.cache
*.pdb
*.obj
*.tmp
*.temp
*.log

# NuGet
packages/
*.nupkg
*.snupkg

# Visual Studio Code
.vscode/

# Rider / JetBrains
.idea/
*.sln.iml

# Backup & crash files
*.bak
*.orig

# Publish output
publish/
*.publishsettings

# Roslyn
*.rsp

# Azure
*.azurePubxml

# IIS Express
iisexpress/
*.db

# Others
*.dbmdl
*.jfm
*.tlog

# Node (falls EmbyIcons Web-Assets enthält)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Images metadata
*.psd
Thumbs.db

# Python tools (falls du Skripte nutzt)
__pycache__/
*.pyc

# MacOS
.DS_Store
